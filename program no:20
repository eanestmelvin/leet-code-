class Solution:
    def isValid(self, s: str) -> bool:
        d = {")": "(", "]": "[", "}": "{"}
        l = []
        for i in s:
            if i in d:
                if not l or l.pop() != d[i]:
                    return False
            else:
                l.append(i)
        return len(l) == 0
