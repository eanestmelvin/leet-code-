class Solution:
    def countPrimes(self, n: int) -> int:
        if n<2:
            return 0
        x=[True]*n
        x[0]=x[1]=False
        i=2
        while((i*i)<n):
            if x[i]:
                for j in range(i*i,n,i):
                    x[j]=False
            i+=1
        return sum(x)
